# Based on josean's dotfiles: https://github.com/josean-dev/dev-environment-files/blob/main/.zshrc
export EDITOR=nvim
export VISUAL=nvim

HISTFILE=$HOME/.zhistory
SAVEHIST=1000
HISTSIZE=999

setopt share_history 
setopt hist_expire_dups_first
setopt hist_ignore_dups
setopt hist_verify
setopt NO_BEEP
setopt IGNORE_EOF

# VIM 
bindkey -v
bindkey "^H" backward-delete-char
bindkey "^?" backward-delete-char

# STARSHIP
eval "$(starship init zsh)"

# ZOXIDE
eval "$(zoxide init zsh)"

# FZF
export FZF_CTRL_R_OPTS="--height 40% --tmux --reverse"
source <(fzf --zsh)

# ZSH PLUGINS 
source $(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source $(brew --prefix)/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

export NVM_DIR="$HOME/.nvm"
[ -s "/opt/homebrew/opt/nvm/nvm.sh" ] && \. "/opt/homebrew/opt/nvm/nvm.sh"  # This loads nvm
[ -s "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm" ] && \. "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm"  # This loads nvm bash_completion


bindkey '^ ' menu-complete
bindkey '^I' autosuggest-accept

bindkey '^[[A' history-beginning-search-backward
bindkey '^[[B' history-beginning-search-forward

export PATH="$HOME/.local/bin:$PATH"

autoload -Uz compinit
compinit

# Skip slow completion for pnpm run/exec (including partial typing like 'r', 'ru')
_pnpm_custom() {
  if [[ -n ${words[2]} && ( "run" == ${words[2]}* || "exec" == ${words[2]}* ) ]]; then
    return 0
  fi
  (( $+functions[_pnpm] )) && _pnpm "$@"
}
compdef _pnpm_custom pnpm

function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	command yazi "$@" --cwd-file="$tmp"
	IFS= read -r -d '' cwd < "$tmp"
	[ "$cwd" != "$PWD" ] && [ -d "$cwd" ] && builtin cd -- "$cwd"
	rm -f -- "$tmp"
}

ZSH_CONFIG_DIR="$HOME/Developer/dotfiles/zsh"

# Source custom functions
for file in $ZSH_CONFIG_DIR/functions/*.zsh; do
  source "$file"
done
eval "$(rbenv init - zsh)"
